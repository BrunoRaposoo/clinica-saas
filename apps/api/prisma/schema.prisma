generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  professionals Professional[]
  patients      Patient[]
  appointments  Appointment[]

  @@map("clinics")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String
  clinicId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic        Clinic?       @relation(fields: [clinicId], references: [id])
  professional  Professional?

  @@map("users")
}

model Professional {
  id         String   @id @default(uuid())
  userId     String   @unique
  clinicId   String
  specialty  String
  document   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  appointments Appointment[]

  @@map("professionals")
}

model Patient {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  email     String?
  phone     String?
  document  String?
  birthDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  appointments Appointment[]

  @@map("patients")
}

model Appointment {
  id           String   @id @default(uuid())
  clinicId     String
  patientId    String
  professionalId String
  status       String   @default("scheduled")
  startDate    DateTime
  endDate      DateTime
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  patient      Patient      @relation(fields: [patientId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  @@map("appointments")
}